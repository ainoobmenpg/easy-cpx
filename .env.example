# Backend Environment Variables

# CORS settings (comma-separated origins)
# Example: http://localhost:3000,http://127.0.0.1:3000
CORS_ORIGINS=http://localhost:3000

# Database configuration
# SQLite (default): sqlite:///./operational_cpx.db
# PostgreSQL: postgresql://user:password@localhost/operational_cpx
# Example: DATABASE_URL=postgresql://user:password@localhost/operational_cpx
DATABASE_URL=postgresql://cpx:cpx_password@localhost:5432/cpx

# MiniMax AI Configuration
# Get your API key from https://platform.minimax.chat/
MINIMAX_API_KEY=your-minimax-api-key-here
MINIMAX_BASE_URL=https://api.minimax.chat/v1

# Internal API (disable in production)
ENABLE_INTERNAL_ENDPOINTS=false

# Frontend Environment Variables

# API base URL for frontend (must start with http:// or https://)
NEXT_PUBLIC_API_URL=http://localhost:8000
