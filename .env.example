# Backend Environment Variables

# CORS settings (comma-separated origins)
# Example: http://localhost:3000,http://127.0.0.1:3000
CORS_ORIGINS=http://localhost:3000

# Database configuration
# SQLite (default): sqlite:///./operational_cpx.db
# PostgreSQL: postgresql://user:password@localhost/operational_cpx
# Example: DATABASE_URL=postgresql://user:password@localhost/operational_cpx
DATABASE_URL=sqlite:///./operational_cpx.db

# Frontend Environment Variables

# API base URL for frontend (must start with http:// or https://)
NEXT_PUBLIC_API_URL=http://localhost:8000
