{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "OrderParser",
  "description": "Schema for parsing player orders into structured commands",
  "type": "object",
  "required": ["order_type", "target_units", "intent"],
  "properties": {
    "order_type": {
      "type": "string",
      "enum": ["move", "attack", "defend", "support", "retreat", "recon", "supply", "special"],
      "description": "Type of order given by player"
    },
    "target_units": {
      "type": "array",
      "items": {"type": "string"},
      "description": "Unit IDs or unit names targeted by the order"
    },
    "intent": {
      "type": "string",
      "description": "Player's intended outcome (natural language)"
    },
    "location": {
      "type": "object",
      "properties": {
        "x": {"type": "integer"},
        "y": {"type": "integer"},
        "area_name": {"type": "string"}
      },
      "description": "Target location if applicable"
    },
    "parameters": {
      "type": "object",
      "description": "Additional order parameters",
      "properties": {
        "priority": {"type": "string", "enum": ["high", "normal", "low"]},
        "formation": {"type": "string"},
        "timing": {"type": "string"}
      }
    },
    "assumptions": {
      "type": "array",
      "items": {"type": "string"},
      "description": "Ambiguities that were assumed"
    }
  }
}
