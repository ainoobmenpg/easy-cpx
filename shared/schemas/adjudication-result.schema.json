{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AdjudicationResult",
  "description": "Schema for rule engine adjudication results",
  "type": "object",
  "required": ["turn", "results", "events"],
  "properties": {
    "turn": {
      "type": "integer",
      "description": "Current turn number"
    },
    "results": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["order_id", "outcome", "changes"],
        "properties": {
          "order_id": {"type": "string"},
          "outcome": {
            "type": "string",
            "enum": ["success", "partial", "failed", "blocked", "cancelled"]
          },
          "changes": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "type": {"type": "string"},
                "target": {"type": "string"},
                "field": {"type": "string"},
                "old_value": {},
                "new_value": {}
              }
            }
          },
          "reason": {"type": "string"}
        }
      }
    },
    "events": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "type": {"type": "string"},
          "turn": {"type": "integer"},
          "data": {"type": "object"}
        }
      }
    },
    "fog_updates": {
      "type": "array",
      "items": {"type": "string"},
      "description": "Updates to fog of war information"
    }
  }
}
